# ============================================
# TWITTER ENGAGEMENT SQUAD - ENVIRONMENT VARIABLES
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha com suas credenciais reais
# 3. NUNCA commite o arquivo .env no Git
#
# ============================================

# ============================================
# GMAIL SMTP (para envio de e-mails)
# ============================================
# Como obter:
# 1. Acesse https://myaccount.google.com/security
# 2. Ative "Verificação em duas etapas"
# 3. Vá em "Senhas de app"
# 4. Gere uma senha para "Mail" / "Outro dispositivo"
# 5. Use a senha gerada (16 caracteres) no GMAIL_APP_PASSWORD

GMAIL_USER="seu-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ============================================
# APIFY (para scraping do Twitter/X)
# ============================================
# Como obter:
# 1. Crie uma conta em https://apify.com
# 2. Vá em Settings > Integrations > API tokens
# 3. Crie um novo token
# 4. Cole o token abaixo

APIFY_TOKEN="apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ============================================
# TWITTER/X AUTHENTICATION
# ============================================
# Como obter (método via cookies do navegador):
# 
# 1. Faça login no Twitter/X no seu navegador
# 2. Abra as DevTools (F12)
# 3. Vá na aba "Application" > "Cookies" > "https://x.com"
# 4. Copie os valores dos cookies:
#    - auth_token → TWITTER_AUTH_TOKEN
#    - ct0 → TWITTER_CT0
#
# IMPORTANTE: Estes tokens expiram. Se a busca parar de funcionar,
# atualize os valores seguindo os passos acima.

TWITTER_AUTH_TOKEN="seu_auth_token_aqui"
TWITTER_CT0="seu_ct0_token_aqui"


# ============================================
# NOTAS DE SEGURANÇA
# ============================================
#
# - NUNCA compartilhe este arquivo com valores reais
# - NUNCA commite o arquivo .env no Git
# - Revogue tokens imediatamente se forem expostos
# - Use senhas de app do Gmail (não sua senha real)
# - Tokens do Twitter expiram - atualize quando necessário
#
# ============================================
