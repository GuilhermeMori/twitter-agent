# ============================================
# TWITTER SCRAPING SAAS PLATFORM
# ============================================
#
# SETUP:
# 1. cp .env.example .env
# 2. Preencha as credenciais abaixo
# 3. Gere a ENCRYPTION_KEY com o comando indicado
#
# ============================================

# ─── Aplicação ───────────────────────────────
DEBUG=True

# ─── Supabase (obrigatório) ──────────────────
# Obtenha em: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ─── Redis (obrigatório para Celery) ─────────
# Instalação local: https://redis.io/docs/getting-started/
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Criptografia (obrigatório) ──────────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-encryption-key-here

# ─── CORS ────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Frontend (Vite) ─────────────────────────
# Deixe vazio em dev (Vite proxy cuida disso)
# Em produção: URL do backend (ex: https://api.seudominio.com)
VITE_API_BASE_URL=
