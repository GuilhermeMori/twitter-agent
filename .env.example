# ============================================
# TWITTER ENGAGEMENT SQUAD - ENVIRONMENT VARIABLES
# ============================================
# 
# INSTRUÇÕES PARA NOVA MÁQUINA:
# 1. Copie este arquivo para .env (`cp .env.example .env`)
# 2. Preencha com suas credenciais reais abaixo
# 3. O sistema agora lê configurações de `config/research-focus.md` automaticamente
#
# ============================================

# ============================================
# GMAIL SMTP (para envio de e-mails - OBRIGATÓRIO)
# ============================================
# Como obter:
# 1. Acesse https://myaccount.google.com/security
# 2. Ative "Verificação em duas etapas"
# 3. Vá em "Senhas de app" (App Passwords)
# 4. Gere uma senha para "Mail" / "Outro dispositivo"
# 5. Use a senha gerada (16 caracteres sem espaços) abaixo

GMAIL_USER="seu-email@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ============================================
# APIFY (para scraping do Twitter/X)
# ============================================
# Token necessário para o Beto e o Zeca buscarem tweets
# Obtenha em: https://apify.com/settings/integrations

APIFY_TOKEN="apify_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ============================================
# TWITTER/X AUTHENTICATION (Cookies)
# ============================================
# 1. Faça login no Twitter/X no navegador
# 2. DevTools (F12) > Application > Cookies > https://x.com
# 3. Copie auth_token e ct0

TWITTER_AUTH_TOKEN="seu_auth_token"
TWITTER_CT0="seu_ct0"

# ============================================
# DESTINATÁRIO DO RELATÓRIO
# ============================================
# Para quem o relatório será enviado por padrão

REPORT_RECEIVER="kauane@wearegrowth.co"
