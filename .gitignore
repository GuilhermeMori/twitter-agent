# ============================================
# INFORMAÇÕES SENSÍVEIS - NUNCA COMMITAR
# ============================================

# Variáveis de ambiente com tokens e senhas
.env
.env.local
.env.*.local

# ============================================
# DADOS PESSOAIS E HISTÓRICO
# ============================================

# Histórico de execuções (contém dados reais de busca)
squads/*/output/history/
squads/*/output/*.md
squads/*/output/*.doc
squads/*/output/*.docx

# Memória da empresa (pode conter informações confidenciais)
_opensquad/_memory/company.md
_opensquad/_memory/preferences.md

# Memória dos squads (pode conter dados sensíveis)
squads/*/_memory/memories.md
squads/*/_memory/runs.md

# Estado dos squads (dados de execução)
squads/*/state.json

# Logs (podem conter informações sensíveis)
_opensquad/logs/*.log
squads/*/logs/*.log
*.log

# Investigações (podem conter dados de perfis reais)
_opensquad/_investigations/

# ============================================
# NODE.JS
# ============================================

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================
# DASHBOARD
# ============================================

# Build outputs
dashboard/dist/
dashboard/build/
dashboard/.vite/
dashboard/.vite-temp/

# Test results
dashboard/test-results/
dashboard/playwright-report/
dashboard/.last-run.json

# ============================================
# PYTHON (se houver scripts Python)
# ============================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Hypothesis (testes baseados em propriedades)
.hypothesis/

# Coverage
.coverage
*.coverage
htmlcov/
.coverage.*

# Pytest
.pytest_cache/

# ============================================
# IDE E EDITORES
# ============================================

# VSCode
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================
# SISTEMA OPERACIONAL
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ============================================
# TEMPORÁRIOS E CACHE
# ============================================

# Arquivos temporários
*.tmp
*.temp
*.swp
*.swo
*~

# Cache
.cache/
.npm/
.eslintcache

# ============================================
# BUILDS E OUTPUTS
# ============================================

# Build folders
_build/
dist/
build/
out/

# ============================================
# ARQUIVOS ESPECÍFICOS DO PROJETO
# ============================================

# Arquivos de backup
*.bak
*.backup
*-old.*

# Arquivos de teste locais
test-local/
scratch/

# Redis dump
dump.rdb

# Configurações locais do MCP
.kiro/settings/mcp.json

# ============================================
# MANTER NO REPOSITÓRIO (EXEMPLOS)
# ============================================

# Manter arquivos de exemplo
!.env.example
!_opensquad/_memory/company.example.md
!_opensquad/_memory/preferences.example.md
!squads/*/output/history/.gitkeep
